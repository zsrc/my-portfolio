---
import { articles } from '../data/articles';
---

<section id="writing" class="section bg-white">
  <div class="container">
    <div class="grid grid-cols-[1fr_2fr] gap-16">

      <!-- Left: heading -->
      <div>
        <div class="border-t border-gray-200 mb-4"></div>
        <h2 class="font-medium text-black" style="font-size: 56px; letter-spacing: -2.2px; line-height: 67.2px;">Writing</h2>
      </div>

      <!-- Right: articles -->
      <div class="divide-y divide-gray-100">
        {articles.map((article) => (
          <a href={article.url} target="_blank" rel="noopener noreferrer" class="block py-7">
            <p class="font-medium text-black leading-snug" style="font-size: 32px; letter-spacing: -1px;">
              {article.title}
            </p>
            <p class="mt-2 font-normal" style="font-size: 20px; letter-spacing: -0.5px; color: rgba(0,0,0,0.45);">
              {article.date} · {article.readTime} read
            </p>
          </a>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    #writing .grid {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }
    #writing h2 {
      font-size: 40px !important;
      letter-spacing: -1.5px !important;
      line-height: 1.2 !important;
      margin-bottom: 16px !important;
    }
    #writing a p:first-child {
      font-size: 22px !important;
    }
    #writing a p:last-child {
      font-size: 16px !important;
    }
  }
</style>
