---
import { projects } from '../data/projects';
---

<section id="work" class="section bg-white">
  <div class="container">
    <div class="border-t border-gray-200 mb-4"></div>
    <h2 class="font-medium text-black mb-10" style="font-size: 56px; letter-spacing: -2.2px; line-height: 67.2px;">Work</h2>

    <div class="bento-wrapper">

      <!-- Row 1: LearnPath — full width horizontal -->
      <a href={`/work/${projects[0].slug}`} class="bento-card bento-featured">
        <div class="bento-img-wrap">
          <img src={projects[0].image} alt={projects[0].title} class="bento-img" onerror="this.style.display='none'" />
        </div>
        <div class="bento-overlay">
          <p class="bento-title">{projects[0].title}</p>
          <p class="bento-desc">{projects[0].subtitle}</p>
        </div>
      </a>

      <!-- Row 2: Rolla + QuizCraft — 760×560 each -->
      <div class="bento-row">
        <a href={`/work/${projects[1].slug}`} class="bento-card" style="flex: 0 1 760px; height: 560px;">
          <div class="bento-img-wrap">
            <img src={projects[1].image} alt={projects[1].title} class="bento-img" onerror="this.style.display='none'" />
          </div>
          <div class="bento-overlay">
            <p class="bento-title">{projects[1].title}</p>
            <p class="bento-desc">{projects[1].subtitle}</p>
          </div>
        </a>
        <a href={`/work/${projects[2].slug}`} class="bento-card" style="flex: 0 1 760px; height: 560px;">
          <div class="bento-img-wrap">
            <img src={projects[2].image} alt={projects[2].title} class="bento-img" onerror="this.style.display='none'" />
          </div>
          <div class="bento-overlay">
            <p class="bento-title">Little Steps Financing:<br />When childcare costs more than rent</p>
            <p class="bento-desc">{projects[2].gridDescription}</p>
          </div>
        </a>
      </div>

      <!-- Row 3: Photon 500px + Grow Pharma fills rest -->
      <div class="bento-row">
        <a href={`/work/${projects[3].slug}`} class="bento-card" style="flex: 0 0 500px; height: 560px;">
          <div class="bento-img-wrap">
            <img src={projects[3].image} alt={projects[3].title} class="bento-img" onerror="this.style.display='none'" />
          </div>
          <div class="bento-overlay">
            <p class="bento-title">{projects[3].title}</p>
            <p class="bento-desc">{projects[3].subtitle}</p>
          </div>
        </a>
        <a href={`/work/${projects[4].slug}`} class="bento-card" style="flex: 1; height: 560px;">
          <div class="bento-img-wrap">
            <img src={projects[4].image} alt={projects[4].title} class="bento-img" onerror="this.style.display='none'" />
          </div>
          <div class="bento-overlay">
            <p class="bento-title">{projects[4].title}</p>
            <p class="bento-desc">{projects[4].subtitle}</p>
          </div>
        </a>
      </div>

      <!-- AI section label -->
      <h2 class="font-medium text-black" style="font-size: 56px; letter-spacing: -2.2px; line-height: 67.2px; margin-top: 24px;">Design Engineering with AI</h2>

      <!-- Row 4: AI placeholder cards -->
      <div class="bento-row">
        <a href="/work/brifstack" class="bento-card bento-placeholder" style="flex: 1; height: 480px; background-color: #3A57FC;">
          <div class="placeholder-inner">
            <span style="font-family: 'Goudy Bookletter 1911', serif; font-size: 80px; letter-spacing: -0.7px; color: #ffffff; line-height: 1;">BrifStack</span>
          </div>
        </a>
        <a href="/work/spotify-playlist-cover-generator" class="bento-card bento-placeholder" style="flex: 1; height: 480px; background-color: #0a0a0a;">
          <div class="placeholder-inner">
            <span style="font-family: 'Inter', sans-serif; font-weight: 700; font-size: 64px; letter-spacing: -1.52px; color: #ffffff; line-height: 1; text-align: center; padding: 0 40px;">Spotify Playlist Cover Generator</span>
          </div>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .bento-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .bento-row {
    display: flex;
    gap: 12px;
  }

  .bento-card {
    position: relative;
    display: block;
    border-radius: 16px;
    overflow: hidden;
    background-color: #f3f4f6;
    text-decoration: none;
    cursor: pointer;
    flex-shrink: 1;
  }

  .bento-featured {
    width: 100%;
    min-height: 480px;
  }

  /* Image */
  .bento-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .bento-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .bento-card:hover .bento-img {
    transform: scale(1.04);
  }

  /* Overlay — slides up from bottom on hover */
  .bento-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .bento-card:hover .bento-overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .bento-title {
    color: #ffffff;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.5px;
    line-height: 1.3;
    margin: 0;
  }

  .bento-desc {
    color: rgba(255,255,255,0.7);
    font-size: 15px;
    font-weight: 400;
    letter-spacing: -0.3px;
    line-height: 1.4;
    margin: 4px 0 0 0;
  }

.bento-placeholder {
    background-color: #f3f4f6;
    cursor: default;
  }

  .placeholder-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-tag {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 999px;
    padding: 6px 16px;
  }

  @media (max-width: 768px) {
    .bento-row {
      flex-direction: column;
    }
    .bento-card {
      flex: none !important;
      width: 100% !important;
      height: 280px !important;
    }
    .bento-featured {
      min-height: 300px !important;
    }
    .bento-overlay {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }
  }
</style>
