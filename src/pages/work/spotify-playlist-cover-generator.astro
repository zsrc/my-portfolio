---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Spotify Playlist Cover Generator — Zehra">

  <!-- Floating pill nav -->
  <nav id="case-nav" class="fixed z-50 flex justify-between items-center">
    <a href="/" class="z-logo" aria-label="Home">
      <svg viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 24px; height: 29px;">
        <path d="M0 23.2727V19.7727L11 5.09091H0.0454546V0H19.0455V3.5L8.04545 18.1818H19V23.2727H0Z" fill="white"/>
      </svg>
    </a>
    <ul class="flex gap-10 font-medium" style="font-size: 20px; letter-spacing: -0.5px; color: #ffffff;">
      <li><a href="/#work">Work</a></li>
      <li><a href="/#writing">Writing</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
  </nav>

  <main style="background-color: #0a0a0a; min-height: 100vh;">

    <!-- Hero text -->
    <section style="padding: 120px 32px 64px; text-align: center; max-width: 960px; margin: 0 auto;">
      <h1 style="font-family: 'Inter', sans-serif; font-weight: 700; font-size: 64px; letter-spacing: -1.52px; color: #ffffff; line-height: 1.1; margin: 0 0 32px 0;">Spotify Playlist Cover Generator</h1>
      <p style="font-size: 20px; line-height: 1.6; color: rgba(255,255,255,0.6); letter-spacing: -0.3px; max-width: 600px; margin: 0 auto;">
        A design-to-code project for AI-generated playlist covers. Built with Claude Code, and powered by fal.ai FLUX Schnell.
      </p>
    </section>

    <!-- Media area -->
    <section style="padding: 0 32px 120px; max-width: 1200px; margin: 0 auto;">
      <div class="video-wrap">
        <video
          id="video-spotify"
          src="/videos/AI Spotify Playlist Covers Generator.mp4"
          loop
          playsinline
          style="width: 100%; border-radius: 20px; display: block;"
        ></video>
        <button class="play-btn" id="play-btn-spotify" aria-label="Play video">
          <svg viewBox="0 0 24 24" fill="white" width="32" height="32"><path d="M8 5v14l11-7z"/></svg>
        </button>
      </div>
    </section>

  </main>

  <style>
    .z-logo {
      display: inline-block;
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .z-logo:hover {
      opacity: 1;
      transform: rotate(-45deg);
    }

    #case-nav {
      opacity: 0;
      pointer-events: none;
      left: 50%;
      transform: translateX(-50%) translateY(-10px);
      width: calc(100% - 64px);
      max-width: 780px;
      top: 20px;
      border-radius: 999px;
      padding: 14px 28px;
      background-color: #111111;
      border: 1px solid #222222;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    #case-nav.scrolled {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }
  </style>

  <style>
    .video-wrap {
      position: relative;
      border-radius: 20px;
      overflow: hidden;
      cursor: pointer;
    }

    .play-btn {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.35);
      border: none;
      cursor: pointer;
      transition: background 0.2s ease, opacity 0.3s ease;
    }

    .play-btn:hover {
      background: rgba(0, 0, 0, 0.5);
    }

    .play-btn svg {
      filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
      width: 64px;
      height: 64px;
    }

    .play-btn.hidden {
      opacity: 0;
      pointer-events: none;
    }
  </style>

  <script>
    const nav = document.getElementById('case-nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    });

    const video = document.getElementById('video-spotify') as HTMLVideoElement;
    const btn = document.getElementById('play-btn-spotify');

    btn?.addEventListener('click', () => {
      video.play();
      btn.classList.add('hidden');
    });

    video?.addEventListener('pause', () => {
      btn.classList.remove('hidden');
    });

    video?.addEventListener('click', () => {
      if (video.paused) {
        video.play();
        btn.classList.add('hidden');
      } else {
        video.pause();
      }
    });
  </script>

</Layout>
