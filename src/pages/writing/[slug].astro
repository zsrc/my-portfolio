---
import Layout from '../../layouts/Layout.astro';
import { articles } from '../../data/articles';

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
---

<Layout title={`${article.title} — Zehra Šarić`}>

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-8 py-5 flex justify-between items-center" style="background-color: #DAF0F7;">
    <a href="/" class="z-logo" aria-label="Home">
      <svg width="20" height="24" viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 23.2727V19.7727L11 5.09091H0.0454546V0H19.0455V3.5L8.04545 18.1818H19V23.2727H0Z" fill="black"/>
      </svg>
    </a>
    <ul class="flex gap-10 text-gray-500 font-medium" style="font-size: 20px; letter-spacing: -0.5px;">
      <li><a href="/#work">Work</a></li>
      <li><a href="/#writing">Writing</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
  </nav>

  <main>

    <!-- Hero -->
    <section style="background-color: #DAF0F7;" class="pt-32 pb-16 px-8">
      <div class="max-w-3xl mx-auto">
        <h1 class="font-medium text-black" style="font-size: 56px; letter-spacing: -2.2px; line-height: 1.1;">
          {article.title}
        </h1>
        <p class="mt-6 font-normal" style="font-size: 20px; letter-spacing: -0.5px; color: rgba(0,0,0,0.45);">
          {article.date} · {article.readTime} read
        </p>
      </div>
    </section>

    <!-- Body -->
    <article class="py-16 px-8">
      <div class="max-w-3xl mx-auto space-y-7">
        {article.body.map((block) => {
          if (block.type === 'h2') {
            return (
              <h2 class="font-medium text-black" style="font-size: 32px; letter-spacing: -1px; margin-top: 2rem;">
                {block.text}
              </h2>
            );
          }
          if (block.type === 'ul') {
            return (
              <ul class="space-y-2 pl-6" style="list-style-type: disc;">
                {block.items!.map((item) => (
                  <li class="font-normal" style="font-size: 24px; letter-spacing: -0.7px; line-height: 1.5; color: rgba(0,0,0,0.659);">
                    {item}
                  </li>
                ))}
              </ul>
            );
          }
          return (
            <p class="font-normal" style="font-size: 24px; letter-spacing: -0.7px; line-height: 1.5; color: rgba(0,0,0,0.659);">
              {block.text}
            </p>
          );
        })}
      </div>
    </article>

  </main>

  <!-- Footer -->
  <footer class="py-8 px-8 border-t border-gray-100">
    <div class="max-w-5xl mx-auto flex justify-between items-center">
      <a href="/" class="z-logo-footer" aria-label="Home">
        <svg width="20" height="24" viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 23.2727V19.7727L11 5.09091H0.0454546V0H19.0455V3.5L8.04545 18.1818H19V23.2727H0Z" fill="black"/>
        </svg>
      </a>
      <nav class="flex gap-7 text-gray-400" style="font-size: 20px;">
        <a href="/#work">Work</a>
        <a href="/#writing">Writing</a>
        <a href="/#about">About</a>
        <a href="/#contact">Contact</a>
      </nav>
    </div>
  </footer>

</Layout>

<style>
  .z-logo, .z-logo-footer {
    display: inline-block;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .z-logo:hover, .z-logo-footer:hover {
    opacity: 1;
    transform: rotate(-45deg);
  }
</style>
